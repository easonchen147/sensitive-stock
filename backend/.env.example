BACKEND_ENV=development
BACKEND_API_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000

# Internal MVP admin credentials. Override locally and do not commit real secrets.
BACKEND_AUTH_ADMIN_USERNAME=admin
BACKEND_AUTH_ADMIN_PASSWORD=change-me
BACKEND_AUTH_TOKEN_SECRET=change-me
BACKEND_AUTH_TOKEN_TTL_SECONDS=28800

BACKEND_HTTP_TIMEOUT=10
BACKEND_MARKET_SECTOR_LIMIT=5
BACKEND_MARKET_NEWS_LIMIT=100

BACKEND_JIN10_FLASH_API_URL=https://flash-api.jin10.com/get_flash_list
BACKEND_JIN10_FALLBACK_URL=https://www.jin10.com/flash_newest.js
BACKEND_JIN10_APP_ID=bVBF4FyRTn5NJF5n
BACKEND_JIN10_API_VERSION=1.0.0
BACKEND_JIN10_CHANNEL=-8200
BACKEND_EASTMONEY_NEWS_URL=https://np-listapi.eastmoney.com/comm/web/getNewsByColumns
BACKEND_SINA_FINANCE_NEWS_URL=https://zhibo.sina.com.cn/api/zhibo/feed

# Optional DeepSeek prediction provider. Without a key, prediction APIs return
# explicit local heuristic results with degraded metadata.
BACKEND_DEEPSEEK_API_KEY=
BACKEND_DEEPSEEK_BASE_URL=https://api.deepseek.com
BACKEND_DEEPSEEK_MODEL=deepseek-v4-flash
BACKEND_DEEPSEEK_THINKING_TYPE=enabled
BACKEND_DEEPSEEK_REASONING_EFFORT=high
BACKEND_DEEPSEEK_TIMEOUT=10
BACKEND_DEEPSEEK_CACHE_TTL_SECONDS=300

# Local prediction history. Empty path uses the backend instance directory.
BACKEND_PREDICTION_HISTORY_PATH=
BACKEND_PREDICTION_HISTORY_LIMIT=200

# Optional market data fallback.
TUSHARE_TOKEN=
